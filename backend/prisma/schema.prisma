generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  VENDOR
}

enum OfferStatus {
  NEW
  IN_REVIEW
  COUNTER_OFFER
  ACCEPTED
  REJECTED
  AWAITING_DELIVERY
  DELIVERED
  ARCHIVED
}

enum OfferTurn {
  BUYER
  VENDOR
}

enum SystemEventType {
  PRICE_CHANGED
  DEAL_ACCEPTED
  TERMS_UPDATED
  DELIVERY_RESCHEDULED
  DELIVERY_CONFIRMED
  OFFER_ARCHIVED
}

enum NotificationType {
  OFFER_MESSAGE
  CHAT_MESSAGE
  OFFER_UPDATE
  SYSTEM
}

model Workspace {
  id              String   @id @default(uuid())
  name            String
  teamInviteToken String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users      User[]
  skus       Sku[]
  offers     Offer[]
  invites    Invite[]
  categories Category[]
}

model Category {
  id             String    @id @default(uuid())
  name           String
  normalizedName String
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  skus           Sku[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, normalizedName])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  inviteToken  String?  @unique
  name         String
  companyName  String
  phone        String?
  avatarPath   String?
  role         UserRole

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  createdSkus    Sku[]            @relation("BuyerSkus")
  offers         Offer[]          @relation("VendorOffers")
  offersReceived Offer[]          @relation("OfferBuyer")
  histories      OfferHistory[]
  messages       OfferMessage[]
  readStates     OfferReadState[]

  chatsAsParticipant1 Chat[]        @relation("ChatParticipant1")
  chatsAsParticipant2 Chat[]        @relation("ChatParticipant2")
  chatMessages        ChatMessage[]

  invitesSent         Invite[] @relation("InviteBuyer")
  invitesUsedAsVendor Invite[] @relation("InviteUsedByVendor")

  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Приглашение поставщика закупщиком. По ссылке с token поставщик регистрируется и получает доступ к SKU этого закупщика.
model Invite {
  id             String     @id @default(uuid())
  token          String     @unique
  buyerId        String
  buyer          User       @relation("InviteBuyer", fields: [buyerId], references: [id])
  usedByVendorId String?
  usedByVendor   User?      @relation("InviteUsedByVendor", fields: [usedByVendorId], references: [id])
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])
  expiresAt      DateTime?
  createdAt      DateTime   @default(now())
}

model Sku {
  id          String    @id @default(uuid())
  name        String
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  uom         String    @default("item")
  articleCode String?
  barcode     String?
  targetPrice Decimal?
  isArchived  Boolean   @default(false)

  createdById String
  createdBy   User   @relation("BuyerSkus", fields: [createdById], references: [id])

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  offerItems OfferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Оффер-контейнер: спільні поля (контрагенти, статус, доставка). Товари — в OfferItem.
model Offer {
  id            String      @id @default(uuid())
  buyerId       String?
  vendorId      String
  initiatorRole UserRole
  deliveryTerms String?
  deliveryDate  DateTime?
  status        OfferStatus @default(NEW)
  currentTurn   OfferTurn
  acceptedAt    DateTime?
  isArchived    Boolean     @default(false)
  archivedAt    DateTime?

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  buyer      User?            @relation("OfferBuyer", fields: [buyerId], references: [id])
  vendor     User             @relation("VendorOffers", fields: [vendorId], references: [id])
  items      OfferItem[]
  histories  OfferHistory[]
  messages   OfferMessage[]
  readStates OfferReadState[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OfferItem {
  id           String  @id @default(uuid())
  offerId      String
  offer        Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  skuId        String?
  sku          Sku?    @relation(fields: [skuId], references: [id])
  productName  String?
  category     String?
  isNovelty    Boolean @default(false)
  currentPrice Decimal
  volume       Int
  unit         String  @default("item")

  initialPrice Decimal  @default(0)
  finalPrice   Decimal?
  savedAmount  Decimal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OfferHistory {
  id String @id @default(uuid())

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id])

  previousPrice Decimal?
  newPrice      Decimal
  comment       String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model OfferMessage {
  id String @id @default(uuid())

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id])

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  content       String?
  isSystemEvent Boolean          @default(false)
  eventType     SystemEventType?
  metaData      Json?

  createdAt DateTime @default(now())
}

model OfferReadState {
  id         String   @id @default(uuid())
  offerId    String
  userId     String
  lastReadAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([offerId, userId])
  @@index([userId])
  @@index([offerId])
}

model Chat {
  id             String   @id @default(uuid())
  participant1Id String
  participant2Id String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participant1 User          @relation("ChatParticipant1", fields: [participant1Id], references: [id])
  participant2 User          @relation("ChatParticipant2", fields: [participant2Id], references: [id])
  messages     ChatMessage[]

  @@unique([participant1Id, participant2Id])
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}
